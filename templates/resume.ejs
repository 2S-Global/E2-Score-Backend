<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Resume</title>
  <script  src="https://cdn.tailwindcss.com" ></script>
  <style type="text/tailwindcss">
    /* Bullet markers for list items that used a custom ::before in the original CSS.
       Kept as a tiny utility layer since Tailwind's `content-['•']` needs the `before:` variant
       repeated on every element — centralizing it here keeps the markup clean. */
    @layer utilities {
      .bullet-item {
        @apply relative pl-3;
      }
      .bullet-item::before {
        content: "•";
        @apply absolute left-0 text-black font-bold;
      }
    }

    /* Ensure the exact same font type is used globally across all elements */
    * {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif !important;
    }

    /* Force text-justify on all descendants within a text-justify block */
    .text-justify, .text-justify * {
      text-align: justify !important;
    }
  </style>
</head>

<body class="m-0 p-0 font-['Segoe_UI',Tahoma,Geneva,Verdana,sans-serif] bg-white text-black text-xs leading-[1.45]">
  <%
    const toTitleCase = (str) => {
      if (!str) return '';
      return str
        .toLowerCase()
        .split(' ')
        .map(word => word.charAt(0).toUpperCase() + word.slice(1))
        .join(' ');
    };
  %>
  <div class="w-full box-border p-0">

    <!-- Header Section -->
    <div class="flex justify-between items-start mb-5">
      <div class="flex-grow pr-5">
        <div class="flex flex-col gap-0.5 mb-2.5">
          <h2 class="m-0 text-2xl font-bold text-black">
            <%= user.name %><% if (user.gender_age) { %><span class="text-[13px] font-medium text-[#555555] ml-1.5 align-middle"><%= user.gender_age %></span><% } %>
          </h2>
          <% if (userDetails.resumeHeadline) { %>
            <span class="m-0 text-sm text-black font-medium"><%= userDetails.resumeHeadline %></span>
          <% } %>
        </div>

        <div class="grid grid-cols-2 gap-x-[15px] gap-y-1.5 text-[11.5px] text-black">
          <div class="flex items-center">
            <span class="inline-flex items-center justify-center w-4 h-4 bg-black text-white rounded-[3px] mr-1.5 flex-shrink-0">
              <i data-lucide="mail" class="inline-block w-2.5 h-2.5 [stroke-width:2.5]"></i>
            </span>
            <span><%= user.email || 'N/A' %></span>
          </div>
          <div class="flex items-center">
            <span class="inline-flex items-center justify-center w-4 h-4 bg-black text-white rounded-[3px] mr-1.5 flex-shrink-0">
              <i data-lucide="phone" class="inline-block w-2.5 h-2.5 [stroke-width:2.5]"></i>
            </span>
            <span><%= user.phone_number || 'N/A' %></span>
          </div>
          <div class="flex items-center">
            <span class="inline-flex items-center justify-center w-4 h-4 bg-black text-white rounded-[3px] mr-1.5 flex-shrink-0">
              <i data-lucide="map-pin" class="inline-block w-2.5 h-2.5 [stroke-width:2.5]"></i>
            </span>
            <span><%= (typeof userPersonalDetails !== 'undefined' && userPersonalDetails?.permanentAddress && userPersonalDetails.permanentAddress !== 'N/A' && userPersonalDetails.permanentAddress.trim() !== '') ? userPersonalDetails.permanentAddress : (candidateDetails?.currentLocation || 'N/A') %></span>
          </div>
          <% if (candidateDetails?.countryName) { %>
          <div class="flex items-center">
            <span class="inline-flex items-center justify-center w-4 h-4 bg-black text-white rounded-[3px] mr-1.5 flex-shrink-0">
              <i data-lucide="flag" class="inline-block w-2.5 h-2.5 [stroke-width:2.5]"></i>
            </span>
            <span><%= candidateDetails.countryName %></span>
          </div>
          <% } %>
          <% if (candidateDetails?.formattedDOB) { %>
          <div class="flex items-center">
            <span class="inline-flex items-center justify-center w-4 h-4 bg-black text-white rounded-[3px] mr-1.5 flex-shrink-0">
              <i data-lucide="calendar" class="inline-block w-2.5 h-2.5 [stroke-width:2.5]"></i>
            </span>
            <span><%= candidateDetails.formattedDOB %></span>
          </div>
          <% } %>
        </div>
      </div>

      <div class="w-[100px] h-[100px] bg-white rounded-full overflow-hidden flex items-center justify-center flex-shrink-0">
        <% const photoUrl = user && user.profilePicture ? user.profilePicture : defaultImageDataUrl %>
        <img src="<%= photoUrl %>" alt="Profile Photo" class="w-full h-full object-cover" />
      </div>
    </div>

    <!-- Profile Summary Section -->
    <% if (userDetails && userDetails.profileSummary) { %>
    <div class="mt-[18px]">
      <h3 class="m-0 mb-2.5 text-black bg-[#f2f2f2] text-center py-1 px-0 text-xs font-bold tracking-[0.5px] capitalize rounded-[2px] w-full box-border [page-break-after:avoid] [break-after:avoid]">Summary</h3>
      <p class="mb-1.5 text-justify"><%= userDetails.profileSummary %></p>
    </div>
    <% } %>

    <!-- Employment History Section -->
    <% if (employment && employment.length > 0) { %>
    <div class="mt-[18px]">
      <h3 class="m-0 mb-2.5 text-black bg-[#f2f2f2] text-center py-1 px-0 text-xs font-bold tracking-[0.5px] capitalize rounded-[2px] w-full box-border [page-break-after:avoid] [break-after:avoid]">Professional Experience</h3>
      <% employment.forEach(job => {
        const monthNames = ["01", "02", "03", "04", "05", "06", "07", "08", "09", "10", "11", "12"];
        const startMonth = job.joiningDate?.month ? monthNames[job.joiningDate.month - 1] : null; 
        const startYear = job.joiningDate?.year;
        const endMonth = job.leavingDate?.month ? monthNames[job.leavingDate.month - 1] : null;
        const endYear = job.leavingDate?.year;
        const formattedStart = startMonth && startYear ? `${startMonth}/${startYear}` : "Unknown";
        const formattedEnd = job.currentEmployment ? "Present" : (endMonth && endYear ? `${endMonth}/${endYear}` : "Unknown");
      %>
      <div class="flex mb-3 leading-[1.4] [page-break-inside:avoid] [break-inside:avoid]">
        <div class="w-[140px] flex-shrink-0 text-black text-[11px] font-semibold pr-[15px]">
          <%= formattedStart %> – <%= formattedEnd %><br>
          <span class="font-normal text-black"><%= job.location || '' %></span>
        </div>
        <div class="flex-grow">
          <span class="font-bold text-black text-[12.5px]"><%= job.companyName %></span>, <span class="text-black inline"><%= job.jobTitle %></span>
          <div class="mt-1.5 text-justify">
            <%- job.jobDescription %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

    <!-- Education Section -->
    <% if (education && education.length > 0) { %>
    <div class="mt-[18px]">
      <h3 class="m-0 mb-2.5 text-black bg-[#f2f2f2] text-center py-1 px-0 text-xs font-bold tracking-[0.5px] capitalize rounded-[2px] w-full box-border [page-break-after:avoid] [break-after:avoid]">Academic Achievements</h3>
      <% education.forEach(edu => { %>
      <div class="flex mb-3 leading-[1.4] [page-break-inside:avoid] [break-inside:avoid]">
        <div class="w-[140px] flex-shrink-0 text-black text-[11px] font-semibold pr-[15px]">
          <% if (edu.levelId === '1' || edu.levelId === '2') { %>
            <%= edu.year_of_passing %>
          <% } else { %>
            <%= edu.from %> – <%= edu.to %>
          <% } %>
        </div>
        <div class="flex-grow">
          <span class="font-bold text-black text-[12.5px]"><%= edu.levelName %></span>
          <span class="text-black mb-1 block">
            <% if (edu.levelId === '1' || edu.levelId === '2') { %>
              <%= edu.board %>
            <% } else { %>
              <%= edu.universityName %>
            <% } %>
          </span>
          <div class="text-xs text-black">
            Marks/Grade:
            <% if (edu.levelId === '1' || edu.levelId === '2') { %>
              <%= edu.marks %>%
            <% } else { %>
              <% if (edu.gradingName && edu.gradingName.includes('Scale')) { %>
                <%= edu.marks %> CGPA
              <% } else if (edu.gradingName && edu.gradingName.includes('Marks')) { %>
                <%= edu.marks %>%
              <% } else { %>
                <%= edu.marks %>
              <% } %>
            <% } %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

    <!-- Skills Section -->
    <% if (userPersonalDetails && userPersonalDetails.skillsResolved && userPersonalDetails.skillsResolved.length > 0) {
      const capitalize = (word) => word.charAt(0).toUpperCase() + word.slice(1);
    %>
    <div class="mt-[18px]">
      <h3 class="m-0 mb-2.5 text-black bg-[#f2f2f2] text-center py-1 px-0 text-xs font-bold tracking-[0.5px] capitalize rounded-[2px] w-full box-border [page-break-after:avoid] [break-after:avoid]">Skills</h3>
      <ul class="grid grid-cols-3 gap-x-3 gap-y-1.5 list-none p-0 m-0 [page-break-inside:avoid] [break-inside:avoid]">
        <% userPersonalDetails.skillsResolved.forEach(skill => { %>
          <li class="bullet-item"><%= skill.split(' ').map(capitalize).join(' ') %></li>
        <% }); %>
      </ul>
    </div>
    <% } %>

    <!-- Languages Section -->
    <% if (userPersonalDetails && userPersonalDetails.languageProficiency && userPersonalDetails.languageProficiency.length > 0) { %>
    <div class="mt-[18px]">
      <h3 class="m-0 mb-2.5 text-black bg-[#f2f2f2] text-center py-1 px-0 text-xs font-bold tracking-[0.5px] capitalize rounded-[2px] w-full box-border [page-break-after:avoid] [break-after:avoid]">Languages</h3>
      <ul class="grid grid-cols-3 gap-x-3 gap-y-1.5 list-none p-0 m-0 [page-break-inside:avoid] [break-inside:avoid]">
        <% userPersonalDetails.languageProficiency.forEach(lang => {
             let skills = [];
             if (lang.read) skills.push("R");
             if (lang.write) skills.push("W");
             if (lang.speak) skills.push("S");
             const skillsText = skills.length > 0 ? ` (${skills.join('/')})` : "";
        %>
          <li class="bullet-item"><strong><%= lang.languageName || 'N/A' %></strong><%= skillsText %></li>
        <% }); %>
      </ul>
    </div>
    <% } %>

    <!-- Projects Section -->
    <% if (projectDetails && projectDetails.length > 0) { %>
    <div class="mt-[18px]">
      <h3 class="m-0 mb-2.5 text-black bg-[#f2f2f2] text-center py-1 px-0 text-xs font-bold tracking-[0.5px] capitalize rounded-[2px] w-full box-border [page-break-after:avoid] [break-after:avoid]">Projects</h3>
      <% projectDetails.forEach(proj => {
        const fromMonth = String(proj.workedFrom?.month || '').padStart(2, '0');
        const toMonth = String(proj.workedTill?.month || '').padStart(2, '0');
      %>
      <div class="flex mb-3 leading-[1.4] [page-break-inside:avoid] [break-inside:avoid]">
        <div class="w-[140px] flex-shrink-0 text-black text-[11px] font-semibold pr-[15px]">
          <%= fromMonth %>/<%= proj.workedFrom?.year || '' %> – <%= toMonth %>/<%= proj.workedTill?.year || '' %>
        </div>
        <div class="flex-grow">
          <span class="font-bold text-black text-[12.5px]"><%= toTitleCase(proj.projectTitle) %></span>
          <div class="mt-1 mb-1.5 text-justify"><%= proj.description %></div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

    <!-- IT Skills & Other Skills Section -->
    <% if ((itSkills && itSkills.length > 0) || (nonTtSkills && nonTtSkills.length > 0)) { %>
    <div class="mt-[18px]">
      <h3 class="m-0 mb-2.5 text-black bg-[#f2f2f2] text-center py-1 px-0 text-xs font-bold tracking-[0.5px] capitalize rounded-[2px] w-full box-border [page-break-after:avoid] [break-after:avoid]">Technical & IT Skills</h3>
      <ul class="grid grid-cols-3 gap-x-3 gap-y-1.5 list-none p-0 m-0 [page-break-inside:avoid] [break-inside:avoid]">
        <% itSkills?.forEach(skill => { %>
          <li class="bullet-item"><strong><%= toTitleCase(skill.skillName) %></strong> <%= skill.version ? `(v${skill.version})` : '' %></li>
        <% }) %>
        <% nonTtSkills?.forEach(skill => { %>
          <li class="bullet-item"><strong><%= toTitleCase(skill.skillName) %></strong></li>
        <% }) %>
      </ul>
    </div>
    <% } %>

    <!-- Candidate & Personal Details Section -->
    <%
      const hasPersonalDetails = typeof candidateDetails !== 'undefined' && candidateDetails && (
        (candidateDetails.fatherName && candidateDetails.fatherName !== "N/A") ||
        (candidateDetails.motherName && candidateDetails.motherName !== "N/A") ||
        (typeof user !== 'undefined' && user && user.gender_name && user.gender_name !== "N/A") ||
        (typeof userPersonalDetails !== 'undefined' && userPersonalDetails && userPersonalDetails.maritalStatusName && userPersonalDetails.maritalStatusName !== "N/A") ||
        (candidateDetails.totalExperience && (candidateDetails.totalExperience.year || candidateDetails.totalExperience.month)) ||
        (candidateDetails.hometown && candidateDetails.hometown !== "N/A") ||
        (typeof userPersonalDetails !== 'undefined' && userPersonalDetails && userPersonalDetails.permanentAddress && userPersonalDetails.permanentAddress !== "N/A") ||
        (typeof userPersonalDetails !== 'undefined' && userPersonalDetails && userPersonalDetails.have_usa_visa !== undefined)
      );
    %>
    <% if (hasPersonalDetails) { %>
    <div class="mt-[18px]">
      <h3 class="m-0 mb-2.5 text-black bg-[#f2f2f2] text-center py-1 px-0 text-xs font-bold tracking-[0.5px] capitalize rounded-[2px] w-full box-border [page-break-after:avoid] [break-after:avoid]">Personal Details</h3>
      <div class="grid grid-cols-2 gap-x-[15px] gap-y-1.5 mt-1.5 [page-break-inside:avoid] [break-inside:avoid]">
        <% if (candidateDetails?.fatherName && candidateDetails.fatherName !== "N/A") { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">Father's Name</div><div class="text-black flex-grow"><%= candidateDetails.fatherName %></div></div>
        <% } %>
        <% if (candidateDetails?.motherName && candidateDetails.motherName !== "N/A") { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">Mother's Name</div><div class="text-black flex-grow"><%= candidateDetails.motherName %></div></div>
        <% } %>
        <% if (typeof user !== 'undefined' && user?.gender_name && user.gender_name !== "N/A") { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">Gender</div><div class="text-black flex-grow"><%= user.gender_name %></div></div>
        <% } %>
        <% if (typeof userPersonalDetails !== 'undefined' && userPersonalDetails?.maritalStatusName && userPersonalDetails.maritalStatusName !== "N/A") { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">Marital Status</div><div class="text-black flex-grow"><%= userPersonalDetails.maritalStatusName %></div></div>
        <% } %>
        <% if (candidateDetails?.totalExperience && (candidateDetails.totalExperience.year || candidateDetails.totalExperience.month)) { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">Total Experience</div><div class="text-black flex-grow"><%= candidateDetails.totalExperience.year || 0 %> yrs <%= candidateDetails.totalExperience.month || 0 %> mos</div></div>
        <% } %>
        <% if (candidateDetails?.hometown && candidateDetails.hometown !== "N/A") { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">Hometown</div><div class="text-black flex-grow"><%= candidateDetails.hometown %></div></div>
        <% } %>
        <% if (typeof userPersonalDetails !== 'undefined' && userPersonalDetails?.permanentAddress && userPersonalDetails.permanentAddress !== "N/A") { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">Permanent Address</div><div class="text-black flex-grow"><%= userPersonalDetails.permanentAddress %></div></div>
        <% } %>
        <% if (typeof userPersonalDetails !== 'undefined' && userPersonalDetails && userPersonalDetails.have_usa_visa !== undefined) { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">Work Permit USA</div><div class="text-black flex-grow"><%= userPersonalDetails.have_usa_visa ? 'Yes' : 'No' %></div></div>
        <% } %>
      </div>
    </div>
    <% } %>

    <!-- Career Profile Section -->
    <%
      const hasCareerProfile = typeof candidateCareerProfile !== 'undefined' && candidateCareerProfile && (
        (candidateCareerProfile.industry_name && candidateCareerProfile.industry_name !== "N/A") ||
        (candidateCareerProfile.department_name && candidateCareerProfile.department_name !== "N/A") ||
        (candidateCareerProfile.job_role_name && candidateCareerProfile.job_role_name !== "N/A") ||
        (candidateCareerProfile.job_type && candidateCareerProfile.job_type !== "N/A") ||
        (candidateCareerProfile.shift && candidateCareerProfile.shift !== "N/A") ||
        (candidateCareerProfile.expected_salary && candidateCareerProfile.expected_salary !== "N/A")
      );
    %>
    <% if (hasCareerProfile) { %>
    <div class="mt-[18px]">
      <h3 class="m-0 mb-2.5 text-black bg-[#f2f2f2] text-center py-1 px-0 text-xs font-bold tracking-[0.5px] capitalize rounded-[2px] w-full box-border [page-break-after:avoid] [break-after:avoid]">Career Profile</h3>
      <div class="grid grid-cols-2 gap-x-[15px] gap-y-1.5 mt-1.5 [page-break-inside:avoid] [break-inside:avoid]">
        <% if (candidateCareerProfile.industry_name && candidateCareerProfile.industry_name !== "N/A") { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">Industry</div><div class="text-black flex-grow"><%= candidateCareerProfile.industry_name %></div></div>
        <% } %>
        <% if (candidateCareerProfile.department_name && candidateCareerProfile.department_name !== "N/A") { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">Department</div><div class="text-black flex-grow"><%= candidateCareerProfile.department_name %></div></div>
        <% } %>
        <% if (candidateCareerProfile.job_role_name && candidateCareerProfile.job_role_name !== "N/A") { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">Job Role</div><div class="text-black flex-grow"><%= candidateCareerProfile.job_role_name %></div></div>
        <% } %>
        <% if (candidateCareerProfile.job_type && candidateCareerProfile.job_type !== "N/A") { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">Job Type</div><div class="text-black flex-grow"><%= candidateCareerProfile.job_type %></div></div>
        <% } %>
        <% if (candidateCareerProfile.shift && candidateCareerProfile.shift !== "N/A") { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">Preferred Shift</div><div class="text-black flex-grow"><%= candidateCareerProfile.shift %></div></div>
        <% } %>
        <% if (candidateCareerProfile.expected_salary && candidateCareerProfile.expected_salary !== "N/A") { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">Expected Salary</div><div class="text-black flex-grow"><%= candidateCareerProfile.expected_salary %></div></div>
        <% } %>
      </div>
    </div>
    <% } %>

    <!-- Publications, Presentations & Patents Section -->
    <% if ((researchPublications && researchPublications.length > 0) || (userPresentations && userPresentations.length > 0) || (userPatents && userPatents.length > 0)) { %>
    <div class="mt-[18px]">
      <h3 class="m-0 mb-2.5 text-black bg-[#f2f2f2] text-center py-1 px-0 text-xs font-bold tracking-[0.5px] capitalize rounded-[2px] w-full box-border [page-break-after:avoid] [break-after:avoid]">Publications, Presentations & Patents</h3>
      <% researchPublications?.forEach(sample => { %>
        <div class="flex mb-3 leading-[1.4] [page-break-inside:avoid] [break-inside:avoid]">
          <div class="w-[140px] flex-shrink-0 text-black text-[11px] font-semibold pr-[15px]">Publication</div>
          <div class="flex-grow">
            <span class="font-bold text-black text-[12.5px]"><%= toTitleCase(sample.title || "Untitled") %></span>
            <% if (sample.url) { %><a href="<%= sample.url %>" class="text-black underline inline-flex items-center gap-[3px] text-[10px] font-semibold ml-[5px]">Link <i data-lucide="external-link" class="inline-block w-[11px] h-[11px] [stroke-width:2.5]"></i></a><% } %>
            <div class="mt-1 mb-1.5 text-justify"><%- sample.description %></div>
          </div>
        </div>
      <% }) %>
      <% userPresentations?.forEach(presentation => { %>
        <div class="flex mb-3 leading-[1.4] [page-break-inside:avoid] [break-inside:avoid]">
          <div class="w-[140px] flex-shrink-0 text-black text-[11px] font-semibold pr-[15px]">Presentation</div>
          <div class="flex-grow">
            <span class="font-bold text-black text-[12.5px]"><%= toTitleCase(presentation.title || "Untitled") %></span>
            <% if (presentation.url) { %><a href="<%= presentation.url %>" class="text-black underline inline-flex items-center gap-[3px] text-[10px] font-semibold ml-[5px]">Link <i data-lucide="external-link" class="inline-block w-[11px] h-[11px] [stroke-width:2.5]"></i></a><% } %>
            <div class="mt-1 mb-1.5 text-justify"><%- presentation.description %></div>
          </div>
        </div>
      <% }) %>
      <% userPatents?.forEach(patent => { %>
        <div class="flex mb-3 leading-[1.4] [page-break-inside:avoid] [break-inside:avoid]">
          <div class="w-[140px] flex-shrink-0 text-black text-[11px] font-semibold pr-[15px]">Patent (<%= patent.status || 'N/A' %>)</div>
          <div class="flex-grow">
            <span class="font-bold text-black text-[12.5px]"><%= toTitleCase(patent.title || "Untitled") %></span> - Office: <%= patent.patent_office || 'N/A' %>
            <div class="mt-1 mb-1.5 text-justify"><%- patent.description %></div>
          </div>
        </div>
      <% }) %>
    </div>
    <% } %>

    <!-- KYC Information Section -->
    <%
      const hasKycData = typeof kycResult !== 'undefined' && kycResult && (
        kycResult.pan_verified || kycResult.aadhar_verified || kycResult.dl_verified || kycResult.passport_verified || kycResult.epic_verified
      );
    %>
    <% if (hasKycData) { %>
    <div class="mt-[18px]">
      <h3 class="m-0 mb-2.5 text-black bg-[#f2f2f2] text-center py-1 px-0 text-xs font-bold tracking-[0.5px] capitalize rounded-[2px] w-full box-border [page-break-after:avoid] [break-after:avoid]">KYC Verification Status</h3>
      <div class="grid grid-cols-2 gap-x-[15px] gap-y-1.5 mt-1.5 [page-break-inside:avoid] [break-inside:avoid]">
        <% if (kycResult.pan_verified) { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">PAN Number</div><div class="text-black flex-grow"><i data-lucide="check-circle" class="inline-block w-[14px] h-[14px] [stroke-width:2.5] align-middle"></i></div></div>
        <% } %>
        <% if (kycResult.aadhar_verified) { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">Aadhaar Number</div><div class="text-black flex-grow"><i data-lucide="check-circle" class="inline-block w-[14px] h-[14px] [stroke-width:2.5] align-middle"></i></div></div>
        <% } %>
        <% if (kycResult.epic_verified) { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">EPIC Number</div><div class="text-black flex-grow"><i data-lucide="check-circle" class="inline-block w-[14px] h-[14px] [stroke-width:2.5] align-middle"></i></div></div>
        <% } %>
        <% if (kycResult.dl_verified) { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">Driving License Number</div><div class="text-black flex-grow"><i data-lucide="check-circle" class="inline-block w-[14px] h-[14px] [stroke-width:2.5] align-middle"></i></div></div>
        <% } %>
        <% if (kycResult.passport_verified) { %>
          <div class="flex leading-[1.35]"><div class="font-semibold w-[150px] text-black flex-shrink-0">Passport Number</div><div class="text-black flex-grow"><i data-lucide="check-circle" class="inline-block w-[14px] h-[14px] [stroke-width:2.5] align-middle"></i></div></div>
        <% } %>
      </div>
    </div>
    <% } %>

    <!-- Certificates Section (Full Width, No Grid) -->
    <% if (userCertifications && userCertifications.length > 0) { %>
    <div class="mt-[18px]">
      <h3 class="m-0 mb-2.5 text-black bg-[#f2f2f2] text-center py-1 px-0 text-xs font-bold tracking-[0.5px] capitalize rounded-[2px] w-full box-border [page-break-after:avoid] [break-after:avoid]">Certificates</h3>
      <div class="flex flex-col gap-1.5">
        <% userCertifications.forEach(cert => { %>
          <div class="bullet-item w-full box-border leading-[1.4] mb-1 [page-break-inside:avoid] [break-inside:avoid]">
            <strong><%= cert.title || "Untitled Certification" %></strong>
            <% if (cert.url) { %>
              <a href="<%= cert.url %>" target="_blank" class="text-black underline inline-flex items-center gap-[3px] text-[10px] font-semibold ml-[5px]">Link <i data-lucide="external-link" class="inline-block w-[11px] h-[11px] [stroke-width:2.5]"></i></a>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- Decorative Divider: Line - Circle - Line -->
    

    <!-- Acknowledgement & Signature Section -->
    <div class="mt-[40px] [page-break-inside:avoid] [break-inside:avoid]">
      <div class="mb-5 leading-[1.4] flex items-start gap-1.5">
        <span class="inline-flex items-center justify-center w-[13px] h-[13px] border border-black rounded-[2px] mr-1.5 flex-shrink-0 mt-0.5">
          <i data-lucide="check" class="inline-block w-2.5 h-2.5 [stroke-width:3.5]"></i>
        </span>
        <span>I hereby declare that all the information provided above is true, correct, and complete to the best of my knowledge and belief.</span>
      </div>
      <div class="flex flex-col items-end gap-4 mt-[50px]">
  <!-- Signature -->
  <div class="flex flex-col items-center">
    <div class="w-[120px] border-t border-black"></div>
    <div class="mt-1 font-semibold">( <%= user.name %> )</div>
  </div>

  <!-- Date -->
  <div class="flex mt-4 items-center text-[11px] font-semibold">
    <span class="mr-2">Date:</span>
    <div class="w-[120px] border-b border-black"></div>
  </div>
</div>
    </div>

    <div class="flex items-center justify-center mt-[80px] mb-[30px] mx-auto w-3/5 gap-[15px]">
      <span class="flex-grow h-px bg-black"></span>
      <span class="w-2 h-2 border-[1.5px] border-black rounded-full bg-black   flex-shrink-0"></span>
      <span class="flex-grow h-px bg-black"></span>
    </div>

  </div>
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    lucide.createIcons();
  </script>
</body>

</html>
