<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Resume</title>
  <style>
    html,
    body {
      margin: 0;
      padding: 0;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: #ffffff;
      color: #000000;
      font-size: 13px;
      line-height: 1.5;
    }

    .container {
      width: 100%;
      box-sizing: border-box;
      padding: 0;
    }

    /* ---------- Header ---------- */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 25px;
    }

    .header-left {
      flex-grow: 1;
      padding-right: 20px;
    }

    .header-title-row {
      display: flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 12px;
    }

    .header-left h2 {
      margin: 0;
      font-size: 28px;
      font-weight: 700;
      color: #000000;
    }

    .header-left .headline {
      margin: 0;
      font-size: 16px;
      font-style: italic;
      color: #000000;
      font-weight: 500;
    }

    /* Contact Info Grid in Header */
    .contact-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 8px 20px;
      font-size: 12.5px;
      color: #000000;
    }

    .contact-item {
      display: flex;
      align-items: center;
    }

    .contact-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 18px;
      height: 18px;
      background-color: #000000;
      color: #ffffff;
      border-radius: 3px;
      margin-right: 8px;
      flex-shrink: 0;
    }

    .contact-badge svg {
      width: 11px;
      height: 11px;
      stroke-width: 2.5;
    }

    .photo {
      width: 110px;
      height: 110px;
      background-color: #ffffff;
      border-radius: 50%;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    /* ---------- Sections ---------- */
    .section {
      margin-top: 22px;
    }

    .section h3 {
      margin: 0 0 14px 0;
      color: #000000;
      background-color: #f2f2f2;
      text-align: center;
      padding: 6px 0;
      font-size: 13.5px;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: capitalize;
      border-radius: 2px;
      width: 100%;
      box-sizing: border-box;
    }

    /* ---------- 2-Column Timeline Layout (Experience, Education, Projects) ---------- */
    .entry-item {
      display: flex;
      margin-bottom: 16px;
      line-height: 1.45;
    }

    .entry-date-col {
      width: 150px;
      flex-shrink: 0;
      color: #000000;
      font-size: 12px;
      font-weight: 600;
      padding-right: 15px;
    }

    .entry-content-col {
      flex-grow: 1;
    }

    .entry-title {
      font-weight: 700;
      color: #000000;
      font-size: 13.5px;
    }

    .entry-subtitle {
      font-style: italic;
      color: #000000;
      margin-bottom: 6px;
      display: block;
    }

    /* ---------- Multi-Column Lists (Skills, Languages, Certificates) ---------- */
    .grid-list {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px 15px;
      list-style-type: none;
      padding: 0;
      margin: 0;
    }

    .grid-list li {
      position: relative;
      padding-left: 14px;
    }

    .grid-list li::before {
      content: "•";
      position: absolute;
      left: 0;
      color: #000000;
      font-weight: bold;
    }

    /* ---------- Detail Rows (Candidate & Personal Details) ---------- */
    .info-list {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px 20px;
      margin-top: 8px;
    }

    .info-row {
      display: flex;
      line-height: 1.4;
    }

    .info-label {
      font-weight: 600;
      width: 170px;
      color: #000000;
      flex-shrink: 0;
    }

    .info-val {
      color: #000000;
      flex-grow: 1;
    }

    /* ---------- General Typography & Lists ---------- */
    p {
      margin: 0 0 8px 0;
      text-align: justify;
    }

    ul {
      margin: 4px 0 0 0;
      padding-left: 18px;
    }

    li {
      margin-bottom: 6px;
    }

    a {
      color: #000000;
      text-decoration: underline;
    }

    a:hover {
      text-decoration: underline;
    }

    /* ---------- Page Breaks ---------- */
    .entry-item,
    .info-list,
    .grid-list,
    .contact-grid {
      page-break-inside: avoid;
      break-inside: avoid;
    }

    .section h3 {
      page-break-after: avoid;
      break-after: avoid;
    }

    /* ---------- KYC Badges ---------- */
    .check {
      color: #000000;
      font-weight: bold;
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }

    .cross {
      color: #000000;
      font-weight: bold;
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }

    .check svg,
    .cross svg {
      width: 12px;
      height: 12px;
      stroke-width: 3;
    }

    .link-icon {
      display: inline-flex;
      align-items: center;
      gap: 3px;
      font-size: 11px;
      font-weight: 600;
      margin-left: 5px;
    }

    .link-icon svg {
      width: 12px;
      height: 12px;
      stroke-width: 2.5;
    }

    i[data-lucide] {
      display: inline-block;
      width: 14px;
      height: 14px;
      stroke-width: 2.5;
      vertical-align: middle;
    }
  </style>
</head>

<body>
  <div class="container">
    <!-- Header Section -->
    <div class="header">
      <div class="header-left">
        <div class="header-title-row">
          <h2><%= user.name %></h2>
          <% if (userDetails.resumeHeadline) { %>
            <span class="headline"><%= userDetails.resumeHeadline %></span>
          <% } %>
        </div>

        <div class="contact-grid">
          <div class="contact-item">
            <span class="contact-badge"><i data-lucide="mail"></i></span>
            <span><%= user.email || 'N/A' %></span>
          </div>
          <div class="contact-item">
            <span class="contact-badge"><i data-lucide="phone"></i></span>
            <span><%= user.phone_number || 'N/A' %></span>
          </div>
          <div class="contact-item">
            <span class="contact-badge"><i data-lucide="map-pin"></i></span>
            <span><%= (typeof userPersonalDetails !== 'undefined' && userPersonalDetails?.permanentAddress && userPersonalDetails.permanentAddress !== 'N/A' && userPersonalDetails.permanentAddress.trim() !== '') ? userPersonalDetails.permanentAddress : (candidateDetails?.currentLocation || 'N/A') %></span>
          </div>
          <% if (candidateDetails?.countryName) { %>
          <div class="contact-item">
            <span class="contact-badge"><i data-lucide="flag"></i></span>
            <span><%= candidateDetails.countryName %></span>
          </div>
          <% } %>
          <% if (candidateDetails?.formattedDOB) { %>
          <div class="contact-item">
            <span class="contact-badge"><i data-lucide="calendar"></i></span>
            <span><%= candidateDetails.formattedDOB %></span>
          </div>
          <% } %>
        </div>
      </div>

      <div class="photo">
        <% const photoUrl = user && user.profilePicture ? user.profilePicture : defaultImageDataUrl %>
        <img src="<%= photoUrl %>" alt="Profile Photo" style="width: 100%; height: 100%; object-fit: cover;" />
      </div>
    </div>

    <!-- Profile Summary Section -->
    <% if (userDetails && userDetails.profileSummary) { %>
    <div class="section">
      <h3>Summary</h3>
      <p><%= userDetails.profileSummary %></p>
    </div>
    <% } %>

    <!-- Employment History Section -->
    <% if (employment && employment.length > 0) { %>
    <div class="section page-break-group">
      <h3>Professional Experience</h3>
      <% employment.forEach(job => { 
        const monthNames = ["01", "02", "03", "04", "05", "06", "07", "08", "09", "10", "11", "12"];
        const startMonth = job.joiningDate?.month ? monthNames[job.joiningDate.month - 1] : null;
        const startYear = job.joiningDate?.year;
        const endMonth = job.leavingDate?.month ? monthNames[job.leavingDate.month - 1] : null;
        const endYear = job.leavingDate?.year;
        const formattedStart = startMonth && startYear ? `${startMonth}/${startYear}` : "Unknown";
        const formattedEnd = job.currentEmployment ? "Present" : (endMonth && endYear ? `${endMonth}/${endYear}` : "Unknown");
      %>
      <div class="entry-item">
        <div class="entry-date-col">
          <%= formattedStart %> – <%= formattedEnd %><br>
          <span style="font-weight: normal; color: #000000;"><%= job.location || '' %></span>
        </div>
        <div class="entry-content-col">
          <span class="entry-title"><%= job.companyName %></span>, <span class="entry-subtitle" style="display:inline;"><%= job.jobTitle %></span>
          <div style="margin-top: 6px;">
            <%- job.jobDescription %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

    <!-- Education Section -->
    <% if (education && education.length > 0) { %>
    <div class="section page-break-group">
      <h3>Education</h3>
      <% education.forEach(edu => { %>
      <div class="entry-item">
        <div class="entry-date-col">
          <% if (edu.levelId === '1' || edu.levelId === '2') { %>
            <%= edu.year_of_passing %>
          <% } else { %>
            <%= edu.from %> – <%= edu.to %>
          <% } %>
        </div>
        <div class="entry-content-col">
          <span class="entry-title"><%= edu.levelName %></span>
          <span class="entry-subtitle">
            <% if (edu.levelId === '1' || edu.levelId === '2') { %>
              <%= edu.board %>
            <% } else { %>
              <%= edu.universityName %>
            <% } %>
          </span>
          <div style="font-size: 12px; color: #000000;">
            Marks/Grade: 
            <% if (edu.levelId === '1' || edu.levelId === '2') { %>
              <%= edu.marks %>%
            <% } else { %>
              <% if (edu.gradingName && edu.gradingName.includes('Scale')) { %>
                <%= edu.marks %> CGPA
              <% } else if (edu.gradingName && edu.gradingName.includes('Marks')) { %>
                <%= edu.marks %>%
              <% } else { %>
                <%= edu.marks %>
              <% } %>
            <% } %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

    <!-- Skills Section -->
    <% if (userPersonalDetails && userPersonalDetails.skillsResolved && userPersonalDetails.skillsResolved.length > 0) { 
      const capitalize = (word) => word.charAt(0).toUpperCase() + word.slice(1);
    %>
    <div class="section page-break-group">
      <h3>Skills</h3>
      <ul class="grid-list">
        <% userPersonalDetails.skillsResolved.forEach(skill => { %>
          <li><%= skill.split(' ').map(capitalize).join(' ') %></li>
        <% }); %>
      </ul>
    </div>
    <% } %>

    <!-- Languages Section -->
    <% if (userPersonalDetails && userPersonalDetails.languageProficiency && userPersonalDetails.languageProficiency.length > 0) { %>
    <div class="section page-break-group">
      <h3>Languages</h3>
      <ul class="grid-list">
        <% userPersonalDetails.languageProficiency.forEach(lang => { 
             let skills = [];
             if (lang.read) skills.push("R");
             if (lang.write) skills.push("W");
             if (lang.speak) skills.push("S");
             const skillsText = skills.length > 0 ? ` (${skills.join('/')})` : "";
        %>
          <li><strong><%= lang.languageName || 'N/A' %></strong><%= skillsText %></li>
        <% }); %>
      </ul>
    </div>
    <% } %>

    <!-- Certifications Section -->
    <% if (userCertifications && userCertifications.length > 0) { %>
    <div class="section page-break-group">
      <h3>Certificates</h3>
      <ul class="grid-list">
        <% userCertifications.forEach(cert => { %>
          <li>
            <strong><%= cert.title || "Untitled Certification" %></strong>
            <% if (cert.url) { %>
              <a href="<%= cert.url %>" target="_blank" class="link-icon">Link <i data-lucide="external-link"></i></a>
            <% } %>
          </li>
        <% }) %>
      </ul>
    </div>
    <% } %>

    <!-- Projects Section -->
    <% if (projectDetails && projectDetails.length > 0) { %>
    <div class="section page-break-group">
      <h3>Projects</h3>
      <% projectDetails.forEach(proj => {
        const fromMonth = String(proj.workedFrom?.month || '').padStart(2, '0');
        const toMonth = String(proj.workedTill?.month || '').padStart(2, '0');
      %>
      <div class="entry-item">
        <div class="entry-date-col">
          <%= fromMonth %>/<%= proj.workedFrom?.year || '' %> – <%= toMonth %>/<%= proj.workedTill?.year || '' %>
        </div>
        <div class="entry-content-col">
          <span class="entry-title"><%= proj.projectTitle %></span>
          <p style="margin-top: 4px;"><%= proj.description %></p>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

    <!-- IT Skills & Other Skills Section -->
    <% if ((itSkills && itSkills.length > 0) || (nonTtSkills && nonTtSkills.length > 0)) { %>
    <div class="section page-break-group">
      <h3>Technical & IT Skills</h3>
      <ul class="grid-list">
        <% itSkills?.forEach(skill => { %>
          <li><strong><%= skill.skillName %></strong> <%= skill.version ? `(v${skill.version})` : '' %></li>
        <% }) %>
        <% nonTtSkills?.forEach(skill => { %>
          <li><strong><%= skill.skillName %></strong></li>
        <% }) %>
      </ul>
    </div>
    <% } %>

    <!-- Candidate & Personal Details Section -->
    <%
      const hasPersonalDetails = typeof candidateDetails !== 'undefined' && candidateDetails && (
        (candidateDetails.fatherName && candidateDetails.fatherName !== "N/A") ||
        (candidateDetails.motherName && candidateDetails.motherName !== "N/A") ||
        (typeof user !== 'undefined' && user && user.gender_name && user.gender_name !== "N/A") ||
        (typeof userPersonalDetails !== 'undefined' && userPersonalDetails && userPersonalDetails.maritalStatusName && userPersonalDetails.maritalStatusName !== "N/A") ||
        (candidateDetails.totalExperience && (candidateDetails.totalExperience.year || candidateDetails.totalExperience.month)) ||
        (candidateDetails.hometown && candidateDetails.hometown !== "N/A") ||
        (typeof userPersonalDetails !== 'undefined' && userPersonalDetails && userPersonalDetails.permanentAddress && userPersonalDetails.permanentAddress !== "N/A") ||
        (typeof userPersonalDetails !== 'undefined' && userPersonalDetails && userPersonalDetails.have_usa_visa !== undefined)
      );
    %>
    <% if (hasPersonalDetails) { %>
    <div class="section page-break-group">
      <h3>Personal Details</h3>
      <div class="info-list">
        <% if (candidateDetails?.fatherName && candidateDetails.fatherName !== "N/A") { %>
          <div class="info-row"><div class="info-label">Father's Name</div><div class="info-val"><%= candidateDetails.fatherName %></div></div>
        <% } %>
        <% if (candidateDetails?.motherName && candidateDetails.motherName !== "N/A") { %>
          <div class="info-row"><div class="info-label">Mother's Name</div><div class="info-val"><%= candidateDetails.motherName %></div></div>
        <% } %>
        <% if (typeof user !== 'undefined' && user?.gender_name && user.gender_name !== "N/A") { %>
          <div class="info-row"><div class="info-label">Gender</div><div class="info-val"><%= user.gender_name %></div></div>
        <% } %>
        <% if (typeof userPersonalDetails !== 'undefined' && userPersonalDetails?.maritalStatusName && userPersonalDetails.maritalStatusName !== "N/A") { %>
          <div class="info-row"><div class="info-label">Marital Status</div><div class="info-val"><%= userPersonalDetails.maritalStatusName %></div></div>
        <% } %>
        <% if (candidateDetails?.totalExperience && (candidateDetails.totalExperience.year || candidateDetails.totalExperience.month)) { %>
          <div class="info-row"><div class="info-label">Total Experience</div><div class="info-val"><%= candidateDetails.totalExperience.year || 0 %> yrs <%= candidateDetails.totalExperience.month || 0 %> mos</div></div>
        <% } %>
        <% if (candidateDetails?.hometown && candidateDetails.hometown !== "N/A") { %>
          <div class="info-row"><div class="info-label">Hometown</div><div class="info-val"><%= candidateDetails.hometown %></div></div>
        <% } %>
        <% if (typeof userPersonalDetails !== 'undefined' && userPersonalDetails?.permanentAddress && userPersonalDetails.permanentAddress !== "N/A") { %>
          <div class="info-row"><div class="info-label">Permanent Address</div><div class="info-val"><%= userPersonalDetails.permanentAddress %></div></div>
        <% } %>
        <% if (typeof userPersonalDetails !== 'undefined' && userPersonalDetails && userPersonalDetails.have_usa_visa !== undefined) { %>
          <div class="info-row"><div class="info-label">Work Permit USA</div><div class="info-val"><%= userPersonalDetails.have_usa_visa ? 'Yes' : 'No' %></div></div>
        <% } %>
      </div>
    </div>
    <% } %>

    <!-- Career Profile Section -->
    <% 
      const hasCareerProfile = typeof candidateCareerProfile !== 'undefined' && candidateCareerProfile && (
        (candidateCareerProfile.industry_name && candidateCareerProfile.industry_name !== "N/A") ||
        (candidateCareerProfile.department_name && candidateCareerProfile.department_name !== "N/A") ||
        (candidateCareerProfile.job_role_name && candidateCareerProfile.job_role_name !== "N/A") ||
        (candidateCareerProfile.job_type && candidateCareerProfile.job_type !== "N/A") ||
        (candidateCareerProfile.shift && candidateCareerProfile.shift !== "N/A") ||
        (candidateCareerProfile.expected_salary && candidateCareerProfile.expected_salary !== "N/A")
      );
    %>
    <% if (hasCareerProfile) { %>
    <div class="section page-break-group">
      <h3>Career Profile</h3>
      <div class="info-list">
        <% if (candidateCareerProfile.industry_name && candidateCareerProfile.industry_name !== "N/A") { %>
          <div class="info-row"><div class="info-label">Industry</div><div class="info-val"><%= candidateCareerProfile.industry_name %></div></div>
        <% } %>
        <% if (candidateCareerProfile.department_name && candidateCareerProfile.department_name !== "N/A") { %>
          <div class="info-row"><div class="info-label">Department</div><div class="info-val"><%= candidateCareerProfile.department_name %></div></div>
        <% } %>
        <% if (candidateCareerProfile.job_role_name && candidateCareerProfile.job_role_name !== "N/A") { %>
          <div class="info-row"><div class="info-label">Job Role</div><div class="info-val"><%= candidateCareerProfile.job_role_name %></div></div>
        <% } %>
        <% if (candidateCareerProfile.job_type && candidateCareerProfile.job_type !== "N/A") { %>
          <div class="info-row"><div class="info-label">Job Type</div><div class="info-val"><%= candidateCareerProfile.job_type %></div></div>
        <% } %>
        <% if (candidateCareerProfile.shift && candidateCareerProfile.shift !== "N/A") { %>
          <div class="info-row"><div class="info-label">Preferred Shift</div><div class="info-val"><%= candidateCareerProfile.shift %></div></div>
        <% } %>
        <% if (candidateCareerProfile.expected_salary && candidateCareerProfile.expected_salary !== "N/A") { %>
          <div class="info-row"><div class="info-label">Expected Salary</div><div class="info-val"><%= candidateCareerProfile.expected_salary %></div></div>
        <% } %>
      </div>
    </div>
    <% } %>

    <!-- Publications, Presentations & Patents Section -->
    <% if ((researchPublications && researchPublications.length > 0) || (userPresentations && userPresentations.length > 0) || (userPatents && userPatents.length > 0)) { %>
    <div class="section page-break-group">
      <h3>Publications, Presentations & Patents</h3>
      <% researchPublications?.forEach(sample => { %>
        <div class="entry-item">
          <div class="entry-date-col">Publication</div>
          <div class="entry-content-col">
            <span class="entry-title"><%= sample.title || "Untitled" %></span>
            <% if (sample.url) { %><a href="<%= sample.url %>" class="link-icon">Link <i data-lucide="external-link"></i></a><% } %>
            <p style="margin-top: 4px;"><%- sample.description %></p>
          </div>
        </div>
      <% }) %>
      <% userPresentations?.forEach(presentation => { %>
        <div class="entry-item">
          <div class="entry-date-col">Presentation</div>
          <div class="entry-content-col">
            <span class="entry-title"><%= presentation.title || "Untitled" %></span>
            <% if (presentation.url) { %><a href="<%= presentation.url %>" class="link-icon">Link <i data-lucide="external-link"></i></a><% } %>
            <p style="margin-top: 4px;"><%- presentation.description %></p>
          </div>
        </div>
      <% }) %>
      <% userPatents?.forEach(patent => { %>
        <div class="entry-item">
          <div class="entry-date-col">Patent (<%= patent.status || 'N/A' %>)</div>
          <div class="entry-content-col">
            <span class="entry-title"><%= patent.title || "Untitled" %></span> - Office: <%= patent.patent_office || 'N/A' %>
            <p style="margin-top: 4px;"><%- patent.description %></p>
          </div>
        </div>
      <% }) %>
    </div>
    <% } %>

    <!-- KYC Information Section -->
    <% 
      const hasKycData = typeof kycResult !== 'undefined' && kycResult && (
        kycResult.pan_verified || kycResult.aadhar_verified || kycResult.dl_verified || kycResult.passport_verified
      );
    %>
    <% if (hasKycData) { %>
    <div class="section page-break-group">
      <h3>KYC Verification Status</h3>
      <div class="info-list">
        <% if (kycResult.pan_verified) { %>
          <div class="info-row"><div class="info-label">PAN Card</div><div class="info-val"><span class="check">Verified <i data-lucide="check"></i></span></div></div>
        <% } %>
        <% if (kycResult.aadhar_verified) { %>
          <div class="info-row"><div class="info-label">Aadhar Card</div><div class="info-val"><span class="check">Verified <i data-lucide="check"></i></span></div></div>
        <% } %>
        <% if (kycResult.dl_verified) { %>
          <div class="info-row"><div class="info-label">Driving License</div><div class="info-val"><span class="check">Verified <i data-lucide="check"></i></span></div></div>
        <% } %>
        <% if (kycResult.passport_verified) { %>
          <div class="info-row"><div class="info-label">Passport</div><div class="info-val"><span class="check">Verified <i data-lucide="check"></i></span></div></div>
        <% } %>
      </div>
    </div>
    <% } %>

  </div>
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    lucide.createIcons();
  </script>
</body>

</html>