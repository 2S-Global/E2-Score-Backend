<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= name %> - Resume</title>

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        body{
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
    </style>
</head>

<body class="bg-slate-100 font-sans">

    <div class="max-w-5xl mx-auto my-10 bg-white shadow-2xl rounded-xl overflow-hidden">

        <!-- Header -->
        <div class="bg-slate-900 text-white px-10 py-8">
            <h1 class="text-4xl font-bold tracking-wide">
                <%= name %>
            </h1>

            <p class="text-xl text-slate-300 mt-2">
                <%= title %>
            </p>

            <div class="flex flex-wrap gap-6 mt-6 text-sm text-slate-300">

                <div>
                    📍 <%= location %>
                </div>

                <div>
                    📧 <%= email %>
                </div>

                <div>
                    📞 <%= phone %>
                </div>

            </div>
        </div>

        <!-- Body -->
        <div class="grid grid-cols-3">

            <!-- Left Sidebar -->
            <div class="bg-slate-50 border-r p-8">

                <!-- Skills -->
                <div class="mb-10">
                    <h2 class="text-lg font-bold border-b pb-2 text-slate-800">
                        Skills
                    </h2>

                    <div class="flex flex-wrap gap-2 mt-4">

                        <% skills.forEach(skill=> { %>

                            <span
                                class="bg-blue-100 text-blue-700 text-sm font-medium px-3 py-1 rounded-full">
                                <%= skill %>
                            </span>

                        <% }) %>

                    </div>
                </div>

                <!-- Contact -->
                <div>

                    <h2 class="text-lg font-bold border-b pb-2 text-slate-800">
                        Contact
                    </h2>

                    <div class="mt-4 space-y-3 text-sm text-gray-700">

                        <p>
                            <span class="font-semibold">Email</span><br>
                            <%= email %>
                        </p>

                        <p>
                            <span class="font-semibold">Phone</span><br>
                            <%= phone %>
                        </p>

                        <p>
                            <span class="font-semibold">Location</span><br>
                            <%= location %>
                        </p>

                    </div>

                </div>

            </div>

            <!-- Right Content -->
            <div class="col-span-2 p-10">

                <!-- Profile -->
                <section class="mb-10">

                    <h2 class="text-2xl font-bold text-slate-800 border-b pb-2">
                        Professional Summary
                    </h2>

                    <p class="text-gray-700 leading-7 mt-4">
                        Passionate <strong><%= title %></strong> with
                        <strong><%= experience %></strong> of hands-on experience
                        building responsive, scalable and modern web applications.
                        Experienced in creating high-performance user interfaces,
                        collaborating with cross-functional teams, and delivering
                        clean, maintainable code.
                    </p>

                </section>

                <!-- Experience -->
                <section class="mb-10">

                    <h2 class="text-2xl font-bold text-slate-800 border-b pb-2">
                        Experience
                    </h2>

                    <div class="mt-5 border-l-4 border-blue-600 pl-5">

                        <h3 class="text-xl font-semibold">
                            <%= title %>
                        </h3>

                        <p class="text-blue-600 font-medium">
                            <%= currentCompany %>
                        </p>

                        <p class="text-sm text-gray-500 mb-4">
                            <%= experience %>
                        </p>

                        <ul class="list-disc ml-5 space-y-2 text-gray-700">

                            <li>
                                Developed reusable React components using modern
                                JavaScript and TypeScript.
                            </li>

                            <li>
                                Improved application performance and user
                                experience.
                            </li>

                            <li>
                                Worked closely with UI/UX designers to deliver
                                pixel-perfect interfaces.
                            </li>

                            <li>
                                Collaborated with backend developers and
                                participated in Agile development.
                            </li>

                        </ul>

                    </div>

                </section>

                <!-- Education -->
                <section>

                    <h2 class="text-2xl font-bold text-slate-800 border-b pb-2">
                        Education
                    </h2>

                    <div class="mt-5">

                        <h3 class="font-semibold text-lg">
                            <%= education %>
                        </h3>

                        <p class="text-gray-600">
                            Computer Science & Engineering
                        </p>

                    </div>

                </section>

            </div>

        </div>

    </div>

</body>
</html>